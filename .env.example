# Konfigurasi Firebase — salin file ini menjadi `.env` lalu isi nilainya.
# Ambil dari Firebase Console → Project settings → Your apps → SDK setup and configuration.
# Prefiks VITE_ wajib agar terbaca oleh Vite di sisi klien.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
